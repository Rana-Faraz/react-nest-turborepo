{
  "name": "ninja-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "knip": "turbo run knip",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "init:project": "node ./scripts/init-project.mjs"
  },
  "devDependencies": {
    "knip": "^6.1.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "patchedDependencies": {
      "@hedystia/better-auth-typeorm@0.8.0": "patches/@hedystia__better-auth-typeorm@0.8.0.patch"
    }
  }
}
