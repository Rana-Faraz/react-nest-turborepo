{
  "name": "worker",
  "version": "0.0.1",
  "description": "Tournament background worker",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun build ./src/main.ts --target bun --outdir ./dist --sourcemap",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "dev": "bun --watch run ./src/main.ts",
    "lint": "pnpm run check-types",
    "start": "bun run ./src/main.ts",
    "start:dist": "bun run ./dist/main.js",
    "test": "bun test ./tests/unit",
    "test:coverage": "bun test ./tests/unit --coverage",
    "test:watch": "bun test ./tests/unit --watch"
  },
  "dependencies": {
    "@repo/jobs": "workspace:*",
    "bullmq": "^5.61.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "18.15.11",
    "typescript": "^5.9.2"
  }
}
