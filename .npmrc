# Hoist all dependencies to root node_modules
# This ensures native modules and all dependencies are accessible
shamefully-hoist=true

# Use isolated node linker for better compatibility with native modules
# This ensures each package gets its own dependencies when needed
public-hoist-pattern[]=*

# Ensure strict peer dependencies checking is disabled for compatibility
strict-peer-dependencies=false

# Allow scripts to run (needed for native module compilation)
enable-pre-post-scripts=true
