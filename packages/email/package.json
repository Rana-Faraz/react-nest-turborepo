{
  "name": "@repo/email",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch --no-clean",
    "dev": "concurrently -k -n preview,build \"email dev --dir ./emails --port 3001\" \"pnpm build:watch\"",
    "lint": "eslint . --max-warnings 0",
    "preview": "email dev --dir ./emails --port 3001"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.9",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "react-email": "5.2.9",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@react-email/components": "1.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.9.3"
  }
}
